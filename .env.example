# Browser mode. Leave unset for the deterministic local demo.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_WORKSPACE_ID=

# Server-only runtime. Never prefix these with VITE_ or ship them to the browser.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
WHATSAPP_APP_SECRET=
WHATSAPP_WORKSPACE_ID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WORKER_TOKEN=
APP_VERSION=
LLM_MODEL=
LLM_PROMPT_VERSION=

# Staging verification only.
STAGING_SUPABASE_URL=
STAGING_SUPABASE_SERVICE_ROLE_KEY=

# Customer simulator provider; server-only, never expose through VITE_ variables.
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
SIMULATOR_LLM_MODEL=
SIMULATOR_LLM_PROMPT_VERSION=simulator-v1
